# Telegram MTProxy runtime configuration managed by Infiproxy.
#
# The service expects the official MTProxy binary at:
# /opt/infiproxy/cores/mtproto/current/mtproto-proxy
#
# Refresh proxy-secret and proxy-multi.conf with:
# sudo infiproxy-manager -> Telegram MTProto setup -> refresh upstream config
MTPROTO_PORT=8443
MTPROTO_STATS_PORT=8888
MTPROTO_SECRET=00000000000000000000000000000000
MTPROTO_WORKERS=2
MTPROTO_AES_PWD=/etc/infiproxy-cores/mtproto/proxy-secret
MTPROTO_PROXY_CONFIG=/etc/infiproxy-cores/mtproto/proxy-multi.conf
